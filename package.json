{
  "name": "alpha-gate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Cloudflare distribution gate for a Sparkle-updated macOS app",
  "scripts": {
    "test": "vitest run --config test/vitest.config.ts",
    "test:watch": "vitest --config test/vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check . && tsc --noEmit && vitest run --config test/vitest.config.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260613.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
